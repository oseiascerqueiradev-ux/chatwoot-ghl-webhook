# Chatwoot
# URL base da sua instancia (sem barra no final)
CHATWOOT_BASE_URL=https://app.chatwoot.com

# Token de API: Settings > Profile > Access Token
CHATWOOT_API_TOKEN=seu_token_aqui

# ID da conta: aparece na URL -> chatwoot.com/app/accounts/123
CHATWOOT_ACCOUNT_ID=123

# Secret do webhook (opcional, mas recomendado)
# Defina o mesmo valor em Settings > Integrations > Webhooks
CHATWOOT_WEBHOOK_SECRET=seu_secret_aqui

# warn: registra assinatura invalida, mas aceita o webhook para nao interromper atendimento.
# enforce: rejeita assinatura invalida com 401 depois que o segredo estiver alinhado no Render.
CHATWOOT_SIGNATURE_MODE=warn

# Inbox de API onde as mensagens espelhadas do GHL vao aparecer no Chatwoot
CHATWOOT_GHL_INBOX_ID=

# Segredo para proteger o webhook /webhook/ghl
GHL_TO_CHATWOOT_WEBHOOK_SECRET=

# Opcional: permite que respostas digitadas no Chatwoot sejam enviadas de volta pelo GHL/WhatsApp
ENABLE_CHATWOOT_TO_GHL_REPLY_SYNC=false
GHL_OUTBOUND_MESSAGE_TYPE=WhatsApp

# GoHighLevel
# Preferencial: Private Integration Token (API v2)
GHL_PRIVATE_INTEGRATION_TOKEN=seu_private_integration_token_aqui

# Legado: API Key antiga. Mantenha vazio se usar o token acima.
GHL_API_KEY=

# Location ID: Settings > Business Info > Location ID
GHL_LOCATION_ID=seu_location_id_aqui

# Opcional: criar oportunidade no GHL quando uma nova conversa nasce no Chatwoot
ENABLE_GHL_OPPORTUNITY_SYNC=false
GHL_OPPORTUNITY_PIPELINE_ID=
GHL_OPPORTUNITY_STAGE_ID=
GHL_OPPORTUNITY_STAGE_ID_OPEN=
GHL_OPPORTUNITY_STAGE_ID_PENDING=
GHL_OPPORTUNITY_STAGE_ID_RESOLVED=

# Controle da IA "Isa" via etiquetas do Chatwoot
# Crie dois webhooks/workflows no GHL: um para pausar a IA e outro para reativar.
ISA_STOP_WEBHOOK_URL=
ISA_START_WEBHOOK_URL=

# Opcional: nomes/aliases das etiquetas separados por virgula
ISA_STOP_LABELS=Stop Isa,stop-isa,stop_isa
ISA_START_LABELS=Star Isa,Start Isa,star-isa,start-isa,star_isa,start_isa

# Servidor
PORT=3000
LOG_LEVEL=info
